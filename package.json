{
    "name": "casecellshop-backend",
    "version": "1.0.0",
    "description": "CaseCellShop backend service - catalog, checkout and order tracking",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "worker": "tsx src/infra/worker.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "bullmq": "^5.7.0",
        "express": "^4.19.2",
        "ioredis": "^5.3.2",
        "pino": "^9.2.0",
        "pino-pretty": "^11.2.1",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^10.0.0",
        "yaml": "^2.4.5"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.14.9",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^1.6.0",
        "tsx": "^4.16.0",
        "typescript": "^5.5.3",
        "vitest": "^1.6.0"
    }
}
