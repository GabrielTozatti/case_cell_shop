PORT=3000
NODE_ENV=development

REDIS_HOST=localhost
REDIS_PORT=6379

# TTL do cache de produtos em segundos (default: 60)
PRODUCT_CACHE_TTL=60

# Delay simulado da API do ERP em ms (default: 3000)
ERP_PROCESSING_DELAY_MS=3000

# Nome da fila BullMQ
CHECKOUT_QUEUE_NAME=checkout

# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info
